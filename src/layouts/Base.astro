---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

// SEO-optimized defaults. The title leads with the brand + the keyword phrase
// people actually search ("AI coding agent workspace") rather than just the
// tagline. Description stays under 160 chars for clean SERP display.
const {
  title = "BYOCLI — AI Coding Agent Workspace for Any CLI",
  description = "Run any AI coding agent — Claude Code, Codex, Gemini, Aider — in one focused desktop workspace. Live browser preview, visual annotations, and scheduled automations."
} = Astro.props;

// Absolute site URL — social scrapers (OG, Twitter) require absolute image URLs.
const SITE_URL = "https://byocli.pages.dev";
const OG_IMAGE = `${SITE_URL}/BYOCLI-Screenshot.png`;

// Canonical GitHub repo URL — single source of truth for the site.
export const GITHUB_URL = "https://github.com/be9hop/byocli";
export const RELEASES_URL = "https://github.com/be9hop/byocli/releases";

// JSON-LD structured data: SoftwareApplication schema for rich search results.
// Helps Google render a richer result (app name, OS, license, category).
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "BYOCLI",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Windows",
  description,
  url: SITE_URL,
  downloadUrl: RELEASES_URL,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD"
  },
  license: "https://www.gnu.org/licenses/gpl-3.0.html"
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="BYOCLI" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={SITE_URL} />

    <!-- Open Graph (Facebook, LinkedIn, Slack, etc.) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="BYOCLI" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={SITE_URL} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:alt" content="BYOCLI workspace showing sidebar, terminal, browser split, and file tree" />
    <meta property="og:image:width" content="1917" />
    <meta property="og:image:height" content="1079" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />
    <meta name="twitter:image:alt" content="BYOCLI workspace showing sidebar, terminal, browser split, and file tree" />

    <!-- Structured data for rich search results -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Icons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/byocli-app-icon.png" />

    <!-- Fonts: DM Sans + IBM Plex Mono (matches the app) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Theme color matches the dark ink -->
    <meta name="theme-color" content="#000308" />
  </head>
  <body>
    <slot />
  </body>
</html>
