---
// Inline SVG icons keep the build dependency-free.
const features = [
  {
    title: "Any CLI, any agent",
    body: "Claude Code, Codex, Gemini, Aider, Goose, OpenCode — or your own. Profiles auto-detect when you launch an agent, and BYOCLI restores native session history via --continue and --resume.",
    icon: `<path d="M4 17l6-6-6-6"/><path d="M12 19h8"/>`
  },
  {
    title: "Point, don't paste",
    body: "The browser split isn't just a preview. Click Annotate, highlight any element, and BYOCLI pastes a structured instruction — selector, XPath, bounds, nearby text — straight into your agent.",
    icon: `<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>`
  },
  {
    title: "Live browser, native",
    body: "A real OS webview (WebView2 / WKWebView / WebKitGTK) running beside your terminals — not a separate window. Multi-tab, navigation, DevTools, media muted by default.",
    icon: `<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`
  },
  {
    title: "Workspace-scoped",
    body: "Each workspace is a real folder with its own terminals, browser tabs, and history. Switch projects without losing your place. State persists across restarts in SQLite.",
    icon: `<path d="M3 7v13h18V7"/><path d="M8 7V4h8v3"/><path d="M3 12h18"/>`
  },
  {
    title: "Schedule the boring stuff",
    body: "Run commands on interval, daily, weekly, or cron. Overlap policies, timeouts, retries, and full output capture. Run in a workspace or a file-free temp sandbox.",
    icon: `<circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/>`
  },
  {
    title: "Open source, GPL-3.0",
    body: "Free to use and modify — and anything built on BYOCLI must stay open too. No vendor lock-in, no telemetry, no account. Just a focused desktop tool.",
    icon: `<path d="M12 2l9 4v6c0 5-3.5 9-9 10-5.5-1-9-5-9-10V6z"/>`
  }
];
---

<section class="section" id="features">
  <div class="container">
    <div class="text-center" style="margin-bottom: 8px;">
      <span class="eyebrow">Features</span>
    </div>
    <h2 class="section-title text-center">A focused shell for AI coding agents</h2>
    <p class="section-lede text-center" style="margin-left: auto; margin-right: auto;">
      BYOCLI doesn't pick your CLI for you. It gives every agent a persistent home,
      a live view of what it's building, and a way to talk about pixels without pasting.
    </p>

    <div class="card-grid">
      {features.map((f) => (
        <div class="card">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon} />
          </div>
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
