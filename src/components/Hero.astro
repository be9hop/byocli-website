---
import { GITHUB_URL, RELEASES_URL } from "../layouts/Base.astro";
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-copy">
      <span class="eyebrow">
        <span class="pulse-dot"></span> Open source · GPL-3.0
      </span>
      <h1>
        Bring <span class="text-mint">your own CLI</span><br />
        to a focused coding workspace.
      </h1>
      <p class="hero-lede">
        Run any AI coding agent — Claude Code, Codex, Gemini, Aider, Goose —
        side-by-side with a live browser and your project files.
        Point at what needs fixing, not paste screenshots.
      </p>
      <div class="hero-ctas">
        <a class="btn btn-primary" href={RELEASES_URL} target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Download for Windows
        </a>
        <a class="btn btn-secondary" href={GITHUB_URL} target="_blank" rel="noopener">
          View on GitHub →
        </a>
      </div>
      <p class="hero-fine">macOS &amp; Linux builds coming soon · v0.1.3</p>
    </div>

    <!-- A CSS mockup of the app, evoking the terminal + browser split -->
    <div class="hero-mockup" aria-hidden="true">
      <div class="mock-window">
        <div class="mock-titlebar">
          <span class="mock-dot"></span>
          <span class="mock-dot"></span>
          <span class="mock-dot"></span>
          <span class="mock-title">BYOCLI — my-project</span>
        </div>
        <div class="mock-body">
          <div class="mock-terminal">
            <div class="mock-line"><span class="mock-prompt">PS</span> my-project&gt; <span class="text-mint">claude</span></div>
            <div class="mock-line mock-muted">✓ Restored session · 3 files in context</div>
            <div class="mock-line mock-out">I'll refactor the auth module.</div>
            <div class="mock-line mock-out">Which approach do you prefer?</div>
            <div class="mock-line"><span class="mock-prompt">›</span> <span class="mock-caret"></span></div>
          </div>
          <div class="mock-browser">
            <div class="mock-browser-bar">
              <span class="mock-lock">🔒</span>
              <span class="mock-url">localhost:1420</span>
            </div>
            <div class="mock-anno">
              <div class="mock-anno-box"></div>
              <div class="mock-anno-tag">Increase this heading's size</div>
            </div>
            <div class="mock-browser-body">
              <div class="mock-el mock-el-head"></div>
              <div class="mock-el"></div>
              <div class="mock-el"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 80px 0 64px;
    position: relative;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 56px;
    align-items: center;
  }
  h1 {
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.08;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin: 24px 0 20px;
  }
  .hero-lede {
    font-size: 19px;
    color: var(--text-muted);
    max-width: 520px;
    margin-bottom: 32px;
  }
  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .hero-fine {
    margin-top: 16px;
    font-size: 13px;
    color: var(--text-faint);
    font-family: var(--font-mono);
  }
  .pulse-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--mint);
    box-shadow: 0 0 0 0 var(--mint-glow);
    animation: pulse 2.4s infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 var(--mint-glow); }
    70% { box-shadow: 0 0 0 8px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  /* ----- mockup ----- */
  .hero-mockup {
    perspective: 1600px;
  }
  .mock-window {
    background: var(--ink-panel);
    border: 1px solid var(--ink-line);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 40px 80px -30px rgba(0,0,0,0.7), 0 0 0 1px rgba(23,245,193,0.06);
    transform: rotateY(-6deg) rotateX(2deg);
    transform-style: preserve-3d;
  }
  .mock-titlebar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 11px 14px;
    background: #050709;
    border-bottom: 1px solid var(--ink-line);
  }
  .mock-dot {
    width: 11px; height: 11px; border-radius: 50%;
    background: var(--ink-line);
  }
  .mock-title {
    margin-left: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
  }
  .mock-body {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    min-height: 320px;
  }
  .mock-terminal {
    padding: 16px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.7;
    border-right: 1px solid var(--ink-line);
  }
  .mock-line { white-space: nowrap; overflow: hidden; }
  .mock-prompt { color: #e0bd5c; }
  .mock-muted { color: var(--text-faint); }
  .mock-out { color: var(--text-muted); }
  .mock-caret {
    display: inline-block;
    width: 7px;
    height: 14px;
    background: var(--mint);
    vertical-align: text-bottom;
    animation: blink 1.1s steps(2) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  .mock-browser { display: flex; flex-direction: column; }
  .mock-browser-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 9px 12px;
    background: #050709;
    border-bottom: 1px solid var(--ink-line);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
  }
  .mock-anno {
    position: relative;
    padding: 14px;
    background: rgba(23,245,193,0.04);
    border-bottom: 1px solid var(--ink-line);
  }
  .mock-anno-box {
    position: absolute;
    top: 14px; left: 14px;
    width: 60%;
    height: 14px;
    border: 2px solid var(--mint);
    border-radius: 3px;
  }
  .mock-anno-tag {
    margin-left: 70%;
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--mint);
    background: var(--ink);
    border: 1px solid var(--mint);
    padding: 3px 7px;
    border-radius: 4px;
    display: inline-block;
  }
  .mock-browser-body { padding: 14px; display: grid; gap: 8px; }
  .mock-el {
    height: 8px;
    background: var(--ink-line);
    border-radius: 3px;
  }
  .mock-el-head { width: 50%; height: 18px; background: #1f262c; }

  @media (max-width: 920px) {
    .hero-inner { grid-template-columns: 1fr; gap: 48px; }
    .hero-mockup { order: -1; }
    .mock-window { transform: none; }
  }
</style>
