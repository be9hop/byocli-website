---
import { GITHUB_URL, RELEASES_URL } from "../layouts/Base.astro";
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-copy">
      <span class="eyebrow">
        <span class="pulse-dot"></span> Open source · GPL-3.0
      </span>
      <h1>
        Bring <span class="text-mint">your own CLI</span><br />
        to a focused coding workspace.
      </h1>
      <p class="hero-lede">
        Run any AI coding agent — Claude Code, Codex, Gemini, Aider, Goose —
        side-by-side with a live browser and your project files.
        Point at what needs fixing, not paste screenshots.
      </p>
      <div class="hero-ctas">
        <a class="btn btn-primary" href={RELEASES_URL} target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Download for Windows
        </a>
        <a class="btn btn-secondary" href={GITHUB_URL} target="_blank" rel="noopener">
          View on GitHub →
        </a>
      </div>
      <p class="hero-fine">macOS &amp; Linux builds coming soon · v0.1.3</p>
    </div>

    <!-- The real app screenshot replaces the earlier CSS mockup. -->
    <div class="hero-mockup">
      <img
        src="/BYOCLI-Screenshot.png"
        alt="BYOCLI workspace showing sidebar, terminal, browser split, and file tree"
        width="1080"
        height="675"
        loading="eager"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 80px 0 64px;
    position: relative;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 56px;
    align-items: center;
  }
  h1 {
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.08;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin: 24px 0 20px;
  }
  .hero-lede {
    font-size: 19px;
    color: var(--text-muted);
    max-width: 520px;
    margin-bottom: 32px;
  }
  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .hero-fine {
    margin-top: 16px;
    font-size: 13px;
    color: var(--text-faint);
    font-family: var(--font-mono);
  }
  .pulse-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--mint);
    box-shadow: 0 0 0 0 var(--mint-glow);
    animation: pulse 2.4s infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 var(--mint-glow); }
    70% { box-shadow: 0 0 0 8px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  /* ----- hero screenshot ----- */
  .hero-mockup {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 40px 80px -30px rgba(0,0,0,0.7), 0 0 0 1px rgba(23,245,193,0.06);
  }
  .hero-mockup img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 12px;
  }

  @media (max-width: 920px) {
    .hero-inner { grid-template-columns: 1fr; gap: 48px; }
    .hero-mockup { order: -1; }
  }
</style>
